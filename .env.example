# ============================================================================
# GeoBIM Stratum Platform — 루트 공통 환경변수
# ----------------------------------------------------------------------------
# 이 파일은 docker-compose.yml 이 참조하는 변수만 포함한다.
# 백엔드/프론트엔드 전용 변수는 각각 backend/.env, frontend/.env 에 둔다.
# 실제 사용 시 `.env` 파일로 복사하고 값을 채울 것.
# ============================================================================

# PostgreSQL (PostGIS)
POSTGRES_USER=geobim
POSTGRES_PASSWORD=geobim_dev_only
POSTGRES_DB=geobim
POSTGRES_PORT=5433

# Redis
REDIS_PORT=6379
