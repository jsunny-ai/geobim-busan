# ============================================================================
# GeoBIM Stratum Backend — 환경변수 예시
# ----------------------------------------------------------------------------
# 실제 사용 시 backend/.env 로 복사하고 값을 채울 것.
# DATABASE_URL, REDIS_URL 의 호스트/포트는 루트 docker-compose 설정과 일치시킬 것.
# ============================================================================

# --- 데이터베이스 ---
# 형식: postgresql+asyncpg://<user>:<password>@<host>:<port>/<db>
DATABASE_URL=postgresql+asyncpg://geobim:geobim_dev_only@localhost:5434/geobim

# Alembic 동기 드라이버 (마이그레이션 실행용)
DATABASE_URL_SYNC=postgresql+psycopg2://geobim:geobim_dev_only@localhost:5434/geobim
DB_SENTINEL_PROJECT_IDS=9708,9718

# --- Redis (Celery 브로커 / 결과 백엔드) ---
REDIS_URL=redis://localhost:6380/0
CELERY_TASK_ALWAYS_EAGER=false

# --- PDF Convert 이식 엔진 ---
# 상대 경로는 backend/ 실행 디렉터리 기준입니다.
PDF_CONVERT_DATA_DIR=pdf_convert
JAVA_BIN_PATH=
PDF_ODL_ENABLED=true
PDF_ODL_OUTPUT_DIR=pdf_convert/data/odl
PDF_ODL_TIMEOUT_SECONDS=60
PDF_ODL_HYBRID_ENABLED=true
PDF_ODL_HYBRID_URL=http://host.docker.internal:5002
PDF_ODL_HYBRID_MODE=full
PDF_MANUAL_ODL_ENABLED=false
PDF_BOX_OCR_ENABLED=true
PDF_BOX_OCR_LANG=kor+eng
PDF_BOX_OCR_SCALE=2.0
PDF_OCR_PROVIDER=tesseract
PDF_OCR_TIMEOUT_SECONDS=60
PDF_OCR_MIN_CONFIDENCE=0.25
PDF_PADDLE_OCR_LANG=korean
PDF_EASYOCR_LANGS=ko,en
PDF_EASYOCR_GPU=false

# --- 보안 / JWT ---
# 운영 환경에서는 반드시 안전한 무작위 키로 교체할 것
SECRET_KEY=change-me-in-production-min-32-chars
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=60

# --- CORS ---
# 콤마로 구분된 origin 목록
CORS_ORIGINS=http://localhost:5180,http://localhost:5181,http://localhost:5182,http://localhost:5183,http://localhost:5184

# --- V-World 타일 프록시 ---
# 국토교통부 브이월드 API 키 (https://www.vworld.kr/)
VWORLD_API_KEY=YOUR_VWORLD_API_KEY_HERE
VWORLD_API_BASE=https://api.vworld.kr
# 공식 V-World 2D Data API에서 실제 조회 검증한 수계 서비스 ID를 콤마로 구분
VWORLD_WATER_SERVICE_IDS=
VWORLD_WATER_CACHE_TTL_SECONDS=86400
COASTAL_LAND_GEOJSON_PATH=
COASTAL_LAND_SOURCE=KHOA
COASTAL_LAND_SOURCE_DATE=
COASTAL_LAND_VERTICAL_DATUM=approx_highest_high_water
COASTAL_LAND_SIMPLIFY_TOLERANCE_DEG=0.000005

# --- 환경 구분 ---
ENVIRONMENT=development
DEBUG=true
